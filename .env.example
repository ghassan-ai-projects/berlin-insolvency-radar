# DeepSeek API (required for LLM agents)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Enable mock agents for local development without API calls
# BI_RADAR_USE_MOCK_AGENTS=true

# Enable real enrichment (Bundesanzeiger, GitHub, company website, Handelsregister)
# BI_RADAR_ENRICH_REAL=1
