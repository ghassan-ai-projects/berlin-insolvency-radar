# Generic OpenAI-compatible LLM configuration
BIRADAR_LLM_PROVIDER=deepseek
BIRADAR_LLM_API_KEY=sk-your-key-here
BIRADAR_LLM_BASE_URL=https://api.deepseek.com/v1
BIRADAR_LLM_MODEL=deepseek-chat
BIRADAR_LLM_TIMEOUT_SECONDS=30
BIRADAR_LLM_MAX_RETRIES=1
BIRADAR_LLM_RETRY_BACKOFF_SECONDS=1.5

# Backward-compatible DeepSeek variables are still supported
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30

# Live enrichment is controlled in config/sources.yaml
